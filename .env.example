# === Backend (Render) ===

# Banco de dados PostgreSQL
DATABASE_URL=jdbc:postgresql://host:5432/medic_ai
DATABASE_USERNAME=admin
DATABASE_PASSWORD=

# JWT
JWT_SECRET=

# OpenAI
OPENAI_API_KEY=sk-...

# Deepgram
DEEPGRAM_API_KEY=
DEEPGRAM_PROJECT_ID=

# CORS (separar múltiplas origens por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://seu-app.vercel.app

# Cloudflare R2 (opcional)
R2_ENABLED=false
R2_ACCOUNT_ID=
R2_BUCKET_NAME=medic-ai-audios
R2_ACCESS_KEY=
R2_SECRET_KEY=

# Porta do servidor
PORT=8080

# === Frontend (Vercel) ===

# URL da API backend
NEXT_PUBLIC_API_URL=https://seu-backend.onrender.com
